{
  "name": "claude-code-reconstructed",
  "version": "0.2.50",
  "description": "A CLI for Claude - Reconstructed from multiple versions",
  "type": "module",
  "bin": {
    "claude": "./cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/entrypoints/cli.tsx",
    "build": "bun build:clean && bun build:ripgrep && bun build:bundle",
    "build:clean": "rm -rf dist && mkdir -p dist",
    "build:ripgrep": "cp -r vendor/ripgrep dist/",
    "build:bundle": "bun build src/entrypoints/cli.tsx --target=node --outfile=dist/cli.js --sourcemap",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write src",
    "prepublishOnly": "bun run build",
    "start-proxy": "node scripts/start-openrouter-proxy.js",
    "with-openrouter": "USE_OPENROUTER=true ANTHROPIC_BASE_URL=http://localhost:3000 node run-claude.js"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.12.4",
    "@anthropic-ai/sdk": "^0.8.1",
    "@anthropic-ai/vertex-sdk": "^0.7.0",
    "@commander-js/extra-typings": "^13.1.0",
    "@inkjs/ui": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.7.0",
    "@sentry/node": "^9.6.1",
    "@statsig/client-core": "^3.15.0",
    "@statsig/js-client": "^3.15.0",
    "ansi-escapes": "^7.0.0",
    "chalk": "^5.3.0",
    "cli-highlight": "^2.1.11",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "debug": "^4.4.0",
    "diff": "^7.0.0",
    "dotenv": "^16.4.7",
    "env-paths": "^3.0.0",
    "figures": "^6.1.0",
    "glob": "^11.0.1",
    "ink": "^4.3.0",
    "ink-link": "^4.1.0",
    "lodash-es": "^4.17.21",
    "lru-cache": "^11.0.2",
    "marked": "^15.0.7",
    "node-fetch": "^2.7.0",
    "react": "^18.2.0",
    "semver": "^7.7.1",
    "shell-quote": "^1.8.2",
    "spawn-rx": "^5.1.2",
    "statsig-node": "^6.3.1",
    "tsx": "^4.19.3",
    "wrap-ansi": "^9.0.0",
    "zod": "^3.22.2",
    "zod-to-json-schema": "^3.24.4"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.9",
    "@types/node": "^20.5.9",
    "@types/react": "^18.2.21",
    "bun-types": "^1.0.3",
    "eslint": "^8.48.0",
    "prettier": "^3.0.3",
    "typescript": "^5.2.2"
  }
}
